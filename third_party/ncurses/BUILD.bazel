# ncurses — terminal UI library (built from source as static library)
# Dependency for htop/btop when system ncurses is not available.
genrule(
    name = "ncurses",
    srcs = ["@ncurses_src//:all_srcs"],
    outs = ["ncurses-install.tar.gz"],
    cmd = """
        set -e
        export PATH="/opt/homebrew/bin:/usr/local/bin:$$PATH"
        OUT=$$(pwd)/$@
        SRC=$$(pwd)/external/+tool_repos+ncurses_src
        BUILD=$$(mktemp -d)
        INSTALL=$$(mktemp -d)
        cp -r $$SRC/* $$BUILD/
        cd $$BUILD
        ./configure --prefix=$$INSTALL \
            --without-shared --without-debug --without-ada \
            --without-tests --without-manpages \
            --enable-widec --with-default-terminfo-dir=/usr/share/terminfo
        make -j$$(nproc 2>/dev/null || sysctl -n hw.ncpu)
        make install.libs install.includes
        tar czf $$OUT -C $$INSTALL .
        rm -rf $$BUILD $$INSTALL
    """,
    tags = ["no-sandbox"],
    visibility = ["//visibility:public"],
)
