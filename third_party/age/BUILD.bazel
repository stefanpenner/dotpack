# age — file encryption tool (pre-built binary)
# Provides both `age` and `age-keygen`
alias(
    name = "age",
    actual = select({
        "//tools:linux_amd64": "@age_linux_amd64//:age",
        "//tools:linux_arm64": "@age_linux_arm64//:age",
        "//tools:darwin_arm64": "@age_darwin_arm64//:age",
    }),
    visibility = ["//visibility:public"],
)

alias(
    name = "age-keygen",
    actual = select({
        "//tools:linux_amd64": "@age_linux_amd64//:age-keygen",
        "//tools:linux_arm64": "@age_linux_arm64//:age-keygen",
        "//tools:darwin_arm64": "@age_darwin_arm64//:age-keygen",
    }),
    visibility = ["//visibility:public"],
)
