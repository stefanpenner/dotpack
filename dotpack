#!/bin/bash
# dotpack — build, deploy, and manage the hermetic tool bundle
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE_NAME="dotpack"

usage() {
  cat <<'EOF'
Usage: dotpack <command> [options]

Commands:
  build [--os OS] [--arch ARCH]   Build bundle (default: linux/current arch)
  push <host>                     Deploy bundle to remote host via SSH
  status <host>                   Show installed tool versions on host
  install                         Install bundle locally to ~/.local
  clean                           Remove build artifacts and Docker image

Options:
  OS defaults to linux for Docker builds, current OS for local
  ARCH defaults to current machine architecture

Examples:
  dotpack build                   Build for linux/current-arch
  dotpack push nas                Deploy to NAS
  dotpack status nas              Check versions on NAS
  dotpack install                 Install locally
EOF
}

cmd_build() {
  local os=linux
  local arch
  arch="$(uname -m)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --os)   os="$2"; shift 2 ;;
      --arch) arch="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  if [ "$os" = "darwin" ]; then
    echo "==> Building dotpack for darwin/${arch}..."
    local out
    out="$(mktemp -d)"
    bash "$SCRIPT_DIR/scripts/download-binaries.sh" "$out" darwin "$arch"
    # Generate checksums
    find "$out" -type f -executable | sort | xargs shasum -a 256 > "$out/SHA256SUMS"
    tar czf "$SCRIPT_DIR/dotpack-darwin-${arch}.tar.gz" -C "$out" .
    rm -rf "$out"
    ls -lh "$SCRIPT_DIR/dotpack-darwin-${arch}.tar.gz"
  else
    echo "==> Building dotpack for linux/${arch} (Docker)..."
    local platform="linux/amd64"
    case "$arch" in
      aarch64|arm64) platform="linux/arm64" ;;
    esac
    docker build --platform "$platform" -t "$IMAGE_NAME" "$SCRIPT_DIR"

    local output_file="$SCRIPT_DIR/dotpack-linux-${arch}.tar.gz"
    docker run --rm "$IMAGE_NAME" > "$output_file"
    ls -lh "$output_file"
  fi

  echo "==> Build complete."
}

cmd_push() {
  local host="${1:?Usage: dotpack push <host>}"
  local arch
  arch="$(ssh "$host" uname -m)"

  local tarball="$SCRIPT_DIR/dotpack-linux-${arch}.tar.gz"
  if [ ! -f "$tarball" ]; then
    echo "No bundle found at $tarball"
    echo "Run: dotpack build --arch $arch"
    exit 1
  fi

  echo "==> Deploying to $host (~/.local)..."
  ssh "$host" 'mkdir -p ~/.local/bin'
  cat "$tarball" | ssh "$host" 'tar xzf - -C ~/.local'

  # Ensure PATH is configured (idempotent)
  if ! ssh "$host" 'grep -q "dotpack managed PATH" ~/.profile 2>/dev/null'; then
    ssh "$host" 'cat >> ~/.profile' <<'PROFILE'

# dotpack managed PATH
export PATH="$HOME/.local/bin:$HOME/.local/git/bin:$HOME/.local/zsh/bin:$HOME/.local/go/bin:$PATH"
PROFILE
  fi

  echo ""
  cmd_status "$host"
  echo ""
  echo "==> Deploy complete. Start a new shell or: source ~/.profile"
}

cmd_status() {
  local host="${1:?Usage: dotpack status <host>}"
  echo "==> Versions on $host:"
  ssh "$host" '
    export PATH="$HOME/.local/bin:$HOME/.local/git/bin:$HOME/.local/zsh/bin:$HOME/.local/go/bin:$PATH"
    for cmd in zsh git nvim go fzf fd bat rg lsd delta jq direnv lazygit htop; do
      if command -v "$cmd" > /dev/null 2>&1; then
        case "$cmd" in
          zsh)     ver=$(zsh --version 2>&1) ;;
          git)     ver=$(git --version 2>&1) ;;
          nvim)    ver=$(nvim --version 2>&1 | head -1) ;;
          go)      ver=$(go version 2>&1) ;;
          htop)    ver=$(htop --version 2>&1 | head -1) ;;
          lazygit) ver=$(lazygit --version 2>&1 | head -1) ;;
          *)       ver=$("$cmd" --version 2>&1 | head -1) ;;
        esac
        printf "  %-10s %s\n" "$cmd" "$ver"
      else
        printf "  %-10s (not installed)\n" "$cmd"
      fi
    done
  '
}

cmd_install() {
  local os arch tarball
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"
  tarball="$SCRIPT_DIR/dotpack-${os}-${arch}.tar.gz"

  if [ ! -f "$tarball" ]; then
    echo "No bundle found at $tarball"
    echo "Run: dotpack build --os $os --arch $arch"
    exit 1
  fi

  echo "==> Installing to ~/.local..."
  mkdir -p "$HOME/.local"
  tar xzf "$tarball" -C "$HOME/.local"
  echo "==> Done. Ensure PATH includes ~/.local/bin"
}

cmd_clean() {
  echo "==> Cleaning up..."
  rm -f "$SCRIPT_DIR"/dotpack-*.tar.gz
  echo "  Removed tarballs"
  if docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
    docker rmi "$IMAGE_NAME" >/dev/null
    echo "  Removed Docker image"
  fi
  echo "==> Done."
}

case "${1:-}" in
  build)   shift; cmd_build "$@" ;;
  push)    shift; cmd_push "$@" ;;
  status)  shift; cmd_status "$@" ;;
  install) cmd_install ;;
  clean)   cmd_clean ;;
  *)       usage ;;
esac
